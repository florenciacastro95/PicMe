extends ../layouts/layout

block content
  .mb-3
    a.btn.btn-outline-secondary(
      href="#"
      onclick="window.history.back(); return false;"
    )
      i.bi.bi-arrow-left.me-1
      | Volver
  h2.mb-3.fw-bold= publicacion.titulo
  
  if publicacion.imagenes.length > 0
    .row.g-4
      each imagen in publicacion.imagenes
        .col-md-6.col-lg-4
          .card.publicacion-card.shadow-sm
            img.card-img-top.publicacion-img(
              src=imagen.url
              alt=publicacion.titulo
            )
            .small.mb-2
              .d-flex.align-items-center.gap-3
                span
                  i.bi.bi-award-fill.me-1
                  = imagen.promedio || '0.0'
                span.text-muted
                  = imagen.totalVotos || 0
                  |  votos
              .progress.mt-1(style="height:6px")
                .progress-bar(
                  style=`width:${((imagen.promedio || 0)/5)*100}%`
                )
            if user && user.id !== publicacion.usuario_id
              form.d-flex.align-items-center(action="/ratings/imagen/" + imagen.id method="POST")
                .btn-group.w-100
                  each val in [1,2,3,4,5]
                    button.btn.btn-outline-primary(
                      type="submit"
                      name="puntuacion"
                      value=val
                    )
                      = val
            if publicacion.comentarios_habilitados
              hr
              h6.text-secondary.small 
                i.bi.bi-chat-dots-fill.me-1
                | Comentarios (#{imagen.comentarios ? imagen.comentarios.length : 0})
              if user
                form(action="/comments/" + imagen.id
                  method="POST")
                  .mb-3
                    textarea.form-control(name="contenido"
                      required
                      maxlength="1000")
                  button.btn.btn-pink
                      | Comentar
              else
                p Iniciá sesión para comentar

              if imagen.comentarios && imagen.comentarios.length > 0
                each comentario in imagen.comentarios
                  .card.mb-2.shadow-sm
                    .card-body.py-2
                      strong(style="color: var(--pink-dark)")
                        = comentario.usuario.username
                      p.mt-2= comentario.contenido
                      if user && user.id === comentario.usuario_id
                        form(action="/comments/" + comentario.id + "/delete"
                          method="POST")
                          button.btn.btn-sm.btn-danger
                            i.bi.bi-trash-fill.me-1
                            | Eliminar
              else
                  p.text-muted.small.text-center No hay comentarios aún.
            else
                .alert.alert-light.p-1.text-center.small.mb-0
                span.text-muted Comentarios cerrados
  
  p.mt-4.fs-5= publicacion.descripcion
  if publicacion.tags.length > 0
    div.mt-4
      strong
        i.bi.bi-tags-fill.me-1
        | Tags:
      br
      each tag in publicacion.tags
        a.post-tag(
          href="/search?q=" + tag.nombre
        )
          | ##{tag.nombre}
      hr.my-3
      p
        strong
          i.bi.bi-person-fill.me-1
          | Autor:
        a.ms-1(
          href="/profile/" + publicacion.usuario.username
        )=publicacion.usuario.username
    if user && user.id == publicacion.usuario_id
      .d-flex.gap-2.mt-3.post-actions
        a.btn.btn-edit(href="/posts/" + publicacion.id + "/edit")
          i.bi.bi-pencil-fill.me-1
          | Editar

        form(action="/posts/" + publicacion.id + "/delete"
          method="POST")
          button.btn.btn-danger
            i.bi.bi-trash-fill.me-1
            | Eliminar
        form(action="/posts/" + publicacion.id + "/habcomments"
          method="POST")
          if publicacion.comentarios_habilitados
            button.btn.btn-comments
              i.bi.bi-lock-fill.me-1
              | Deshabilitar comentarios
          else
            button.btn.btn-success
              i.bi.bi-unlock-fill.me-1
              | Habilitar comentarios
