extends ../layouts/layout

block content
  .mb-3
    a.btn.btn-outline-secondary(href="#" onclick="window.history.back(); return false;") ⬅ Volver atrás
  h2= publicacion.titulo
  
  if publicacion.imagenes.length > 0
    .row
      each imagen in publicacion.imagenes
        .col-md-4.mb-3
          .card
            img.img-fluid.rounded(
              src=imagen.url
            )
          .card-body.p-2
            .d-flex.justify-content-between.align-items-center.mb-2
              span
                strong ⭐ #{imagen.promedio || '0.0'}
                small.text-muted.ms-1 (#{imagen.totalVotos || 0} votos)

            if user && user.id !== publicacion.usuario_id
              form.d-flex.align-items-center(action="/ratings/imagen/" + imagen.id method="POST")
                select.form-select.form-select-sm.me-2(name="puntuacion" required)
                  option(value="") Nota...
                  each val in [5, 4, 3, 2, 1]
                    option(value=val selected=(imagen.miValoracion === val))= val + ' Estrellas'
                button.btn.btn-sm.btn-primary(type="submit") Valorar
            if publicacion.comentarios_habilitados
              hr
              h6.text-secondary.small  Comentarios (#{imagen.comentarios ? imagen.comentarios.length : 0})
                if user
                  form(action="/comments/imagen/" + imagen.id
                    method="POST")
                    .mb-3
                      textarea.form-control(name="contenido"
                        required
                        maxlength="1000")
                    button.btn.btn-primary
                        | Comentar
                else
                  p Iniciá sesión para comentar

                if imagen.comentarios && imagen.comentarios.length > 0
                    each comentario in imagen.comentarios
                      .card.mb-2
                        .card-body
                          strong= comentario.usuario.username
                          p.mt-2= comentario.contenido
                          if user && user.id === comentario.usuario_id
                            form(action="/comments/" + comentario.id + "/delete"
                              method="POST")
                              button.btn.btn-sm.btn-danger
                                | Eliminar
                else
                p.text-muted.small.text-center No hay comentarios aún.
            else
                .alert.alert-light.p-1.text-center.small.mb-0
                span.text-muted Comentarios cerrados
  
  p.mt-3= publicacion.descripcion
  if publicacion.tags.length > 0
    p
      strong Tags:
      each tag in publicacion.tags
        a.badge.bg-secondary.me-1(
          href="/search?q=" + tag.nombre
        )
          | ##{tag.nombre}
    p
      strong Autor:
        a.ms-1(href="/profile/" + publicacion.usuario.username)=publicacion.usuario.username
    hr

  if user && user.id === publicacion.usuario_id
    hr
    .d-flex.gap-2.mt-3
      a.btn.btn-warning(href="/posts/" + publicacion.id + "/edit")
        | Editar

      form(action="/posts/" + publicacion.id + "/delete"
        method="POST")
        button.btn.btn-danger
          | Eliminar
      form(action="/posts/" + publicacion.id + "/habcomments"
        method="POST")
        if publicacion.comentarios_habilitados
          button.btn.btn-secondary
            | Deshabilitar comentarios
        else
          button.btn.btn-success
            | Habilitar comentarios
