extends ../layouts/layout

block content

  a.btn.btn-sm.btn-outline-secondary.mb-3(href="/") ⬅ Volver al Inicio
  h2 Editar publicación

  form(
    action="/posts/" + publicacion.id + "/edit"
    method="POST"
    enctype="multipart/form-data"
  )

    .mb-3
      label.form-label Título

      input.form-control(
        type="text"
        name="titulo"
        value=publicacion.titulo
      )

    .mb-3
      label.form-label Descripción

      textarea.form-control(
        name="descripcion"
      )= publicacion.descripcion
    h4 Imágenes actuales

    if publicacion.imagenes && publicacion.imagenes.length > 0

      each imagen in publicacion.imagenes

        .mb-3
          img(
            src=imagen.url
            width="200"
          )

          .form-check
            input.form-check-input(
              type="checkbox"
              name="imagenesEliminar"
              value=imagen.id
            )

            label.form-check-label
              | Eliminar imagen
    .mb-3
      label.form-label Agregar imágenes

      input.form-control(
        type="file"
        name="imagenes"
        multiple
      )
      small.form-text.text-muted Elige archivos adicionales. Tamaño máximo por archivo: 3 MB.
    .mb-3
      .form-check
        input.form-check-input(
          type="checkbox"
          id="copyright"
          name="copyright"
          checked=publicacion.copyright
        )
        label.form-check-label(for="copyright")
          | Imagen con copyright
          
    button.btn.btn-primary
      | Guardar cambios