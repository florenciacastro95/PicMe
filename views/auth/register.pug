extends ../layouts/layout

block metadata
  title Registrarse -PicME!
  meta(name="description" content="Crea tu cuenta en PicME!")

block content
  .row.justify-content-center
    .col-md-6
      .card.p-4
          h2.mb-4.text-center Unite a PicME!
          p.text-center.text-muted Todos podemos ser elegidos.

          form(action="/auth/register" method="POST" novalidate)

            .mb-3
              label.form-label(for="username") Usuario
              input.form-control(type="text" name="username" id="username" required)
              .form-text El nombre de usuario debería tener un mínimo de 3 caracteres
            .mb-3
              label.form-label(for="email") Email
              input.form-control(type="email" name="email" id="email" required)

            .mb-3
              label.form-label(for="nombre") Nombre
              input.form-control(type="text" name="nombre" id="nombre")
            .mb-3
              label.form-label(for="password") Contraseña
              input.form-control(type="password" name="password" id="password" required)
              .form-text La contraseña debe tener al menos 6 caracteres y contener al menos un número.
            .mb-3
              label.form-label(for="password-conf") Confirmar contraseña
              input.form-control(type="password" name="password_conf" id="password-conf" required)
            button.btn.btn-success.w-100(type="submit")
              | Registrarse

          p.text-center.mt-3
            | ¿Ya tenés cuenta?
            a.ms-1(href="/auth/login") Iniciá sesión