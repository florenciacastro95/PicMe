doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    block metadata
        title PicME!

    link(
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    )

  body
    nav.navbar.navbar-expand-lg.navbar-light.bg-light
      .container
        a.navbar-brand(href="/") PicME!
        form.d-flex.mx-auto.my-2.my-lg-0(action="/search" method="GET" style="max-width: 400px; width: 100%;")
          input.form-control.me-2(
            type="search"
            name="q"
            placeholder="Buscar títulos, descripciones o tags..."
            aria-label="Buscar"
            value=query || ''
          )
          button.btn.btn-outline-primary(type="submit") Buscar
        ul.navbar-nav.ms-auto
          li.nav-item
            a.nav-link(href="/auth/login") Iniciar sesión

          li.nav-item
            a.nav-link(href="/auth/register") Registrarse
    .container.mt-4
      block content
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js")