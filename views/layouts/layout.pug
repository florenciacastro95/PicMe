doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    link(rel="icon", type="image/x-icon", href="/assets/logo.ico")
    block metadata
        title PicME!
    link(
      rel="preconnect"
      href="https://fonts.googleapis.com"
    )
    link(
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    )
    link(
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    )
    link(
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
    )
    link(
      href="/css/styles.css"
      rel="stylesheet"
    )

  body
    nav.navbar.navbar-expand-lg.navbar-pink.mb-4
      .container
        a.navbar-brand.fw-bold(href="/")
          i.bi.bi-camera-fill.me-2
          | PicME!
        button.navbar-toggler(type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav")
          span.navbar-toggler-icon
        #navbarNav.collapse.navbar-collapse
          form.d-flex.mx-auto.my-2.my-lg-0(action="/search" method="GET" style="max-width: 400px; width: 100%;")
            input.form-control.me-2.search-input(
              type="search"
              name="q"
              placeholder="Buscar títulos, descripciones o tags..."
              aria-label="Buscar"
              value=(query || '')
            )
            button.btn.btn-light.search-button(type="submit") Buscar
          ul.navbar-nav.ms-auto.align-items-lg-center
            if user
              li.nav-item.me-lg-2
                a.nav-link(href="/profile/" + user.username) Mi perfil
              li.nav-item
                form(action="/auth/logout" method="POST" class="d-inline")
                  button.btn.btn-link.nav-link(type="submit") Cerrar sesión
            else 
              li.nav-item
                a.nav-link(href="/auth/login") Iniciar sesión

              li.nav-item
                a.nav-link(href="/auth/register") Registrarse
    .container.mt-4
      if alert
        .alert.alert-dismissible.fade.show(class="alert-" + alert.type role="alert")
          | #{alert.text}
          button.btn-close(type="button" data-bs-dismiss="alert" aria-label="Cerrar")
      block content
    footer.footer-pink.mt-5.py-4
      .container.text-center
        p.mb-1.fw-semibold
          i.bi.bi-camera-fill.me-2
          | PicME!
        p.small.mb-0
          | Proyecto universitario para el trabajo práctico "FOTAZA 2" Programación Web 2 - ULP. Por Florencia M. Castro
    script.
      (function() {
        var currentPath = window.location.pathname;
        var ref = document.referrer;
        if (ref && !ref.includes(currentPath) && !ref.includes('/comments') && !ref.includes('/ratings')) {
          sessionStorage.setItem('prev_page_' + currentPath, ref);
        }
      })();

      function goBack(fallback) {
        var currentPath = window.location.pathname;
        var guardado = sessionStorage.getItem('prev_page_' + currentPath);
        window.location.href = guardado ? guardado : (fallback || '/');
      }
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js")