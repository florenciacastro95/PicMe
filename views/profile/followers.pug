extends ../layouts/layout

block metadata
  title= 'Seguidores de ' + perfil.username + ' - PicME!'

block content
  .d-flex.justify-content-between.align-items-center.mb-4
    h2.mb-0 Seguidores de #{perfil.username}
    a.btn.btn-outline-secondary(href="/profile/" + perfil.username) Volver

  if seguidores && seguidores.length > 0
    .row
      each seguidor in seguidores
        .col-12.mb-3
          .card
            .card-body.d-flex.justify-content-between.align-items-center
              .d-flex.align-items-center.gap-3
                if seguidor.avatar
                  img.rounded-circle(src=seguidor.avatar alt=seguidor.username width="48" height="48")
                else
                  .rounded-circle.bg-secondary(style="width: 48px; height: 48px;")
                div
                  a.text-decoration-none(href="/profile/" + seguidor.username)= seguidor.username
                  if seguidor.nombre
                    p.text-muted.small.mb-0= seguidor.nombre

              if user && !seguidor.isOwnProfile
                if seguidor.isFollowing
                  form(action="/follow/" + seguidor.id + "/unfollow" method="POST")
                    button.btn.btn-sm.btn-outline-warning(type="submit") Siguiendo
                else
                  form(action="/follow/" + seguidor.id method="POST")
                    button.btn.btn-sm.btn-primary(type="submit") Seguir
  else
    .alert.alert-secondary No tiene seguidores todavia.