extends ../layouts/layout

block metadata
  title= 'Siguiendo de ' + perfil.username + ' - PicME!'

block content
  .d-flex.justify-content-between.align-items-center.mb-4
    h2.mb-0 Seguidos por #{perfil.username}
    a.btn.btn-outline-secondary(href="/profile/" + perfil.username) Volver

  if seguidos && seguidos.length > 0
    .row
      each seguido in seguidos
        .col-12.mb-3
          .card
            .card-body.d-flex.justify-content-between.align-items-center
              .d-flex.align-items-center.gap-3
                if seguido.avatar
                  img.rounded-circle(src=seguido.avatar alt=seguido.username width="48" height="48")
                else
                  .rounded-circle.bg-secondary(style="width: 48px; height: 48px;")
                div
                  a.text-decoration-none(href="/profile/" + seguido.username)= seguido.username
                  if seguido.nombre
                    p.text-muted.small.mb-0= seguido.nombre

              if user && !seguido.isOwnProfile
                if seguido.isFollowing
                  form(action="/follow/" + seguido.id + "/unfollow" method="POST")
                    button.btn.btn-sm.btn-outline-warning(type="submit") Siguiendo
                else
                  form(action="/follow/" + seguido.id method="POST")
                    button.btn.btn-sm.btn-primary(type="submit") Seguir
  else
    .alert.alert-secondary No sigue a nadie todavia.