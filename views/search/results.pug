extends ../layouts/layout

block metadata
  title= query ? 'Buscar: ' + query + ' - PicME!' : 'Buscar - PicME!'

block content
  .container
    h2.mb-4.fw-bold
      i.bi.bi-sliders.me-2.text-pink
      | Motor de Búsqueda PicMe!

    .card.bg-light.shadow-sm.mb-5
      .card-body.p-4
        form(action="/search" method="GET")
          .row.g-3
            .col-10.col-md-6
              label.form-label.small.fw-bold.text-muted Palabra clave (Título, descripción o usuario)
              .input-group
                span.input-group-text.bg-white
                  i.bi.bi-search
                input.form-control(
                  type="text" 
                  name="q" 
                  placeholder="Ej: Comida, fmcastro..." 
                  value=query
                )

            .col-6.col-md-3
              label.form-label.small.fw-bold.text-muted Filtrar por #Tag
              .input-group
                span.input-group-text.bg-white #
                input.form-control(
                  type="text" 
                  name="tag" 
                  placeholder="mascitas" 
                  value=tagFilter
                )
            .col-6.col-md-3
              label.form-label.small.fw-bold.text-muted Tipo de resultado
              select.form-select(name="filterType")
                option(value="all" selected=filterType === 'all') Todo
                option(value="publicaciones" selected=filterType === 'publicaciones') Publicaciones
                option(value="usuarios" selected=filterType === 'usuarios') Usuarios

            .col-12.col-md-4
              label.form-label.small.fw-bold.text-muted Derechos de Autor
              if !user
                select.form-select(name="copyright" disabled)
                  option(value="sin_copyright" selected) Solo imágenes libres (Modo Invitado)
                small.form-text.text-danger Iniciá sesión para ver imágenes con copyright.
              else
                select.form-select(name="copyright")
                  option(value="all" selected=copyrightFilter === 'all') Todos los derechos
                  option(value="sin_copyright" selected=copyrightFilter === 'sin_copyright') Solo contenido libre (Sin Copyright)
                  option(value="copyright" selected=copyrightFilter === 'copyright') Solo contenido protegido (Con Copyright)

            .col-12.col-md-8.d-flex.align-items-end.justify-content-md-end
              button.btn.btn-pink.px-4.w-100.w-md-auto(type="submit")
                i.bi.bi-funnel-fill.me-2
                | Aplicar filtros

  if publicaciones && publicaciones.length > 0
    .row
      each pub in publicaciones
        .col-md-6.col-lg-4.mb-4
          .card.h-100
            if pub.imagenes && pub.imagenes.length > 0
              img.card-img-top(src=pub.imagenes[0].url alt=pub.titulo style="height: 220px; object-fit: cover;")
            else
              .bg-secondary.text-white.d-flex.align-items-center.justify-content-center(style="height: 220px;")
                | Sin imagen
            .card-body
              h5.card-title
                a(href="/posts/" + pub.id)= pub.titulo
              if pub.descripcion
                p.card-text= pub.descripcion
              if pub.tags && pub.tags.length > 0
                p.mb-2
                  each tag in pub.tags.slice(0, 3)
                    a.badge.bg-secondary.me-1.text-decoration-none(href="/search?q=" + tag.nombre)= '#' + tag.nombre
              p.text-muted.small.mb-0
                | Por
                a.ms-1(href="/profile/" + pub.usuario.username)= pub.usuario.username

    if totalPages > 1
      nav.mt-4
        ul.pagination.justify-content-center
          if hasPrevPage
            li.page-item
              a.page-link(href=`/search?q=${query}&tag=${tagFilter}&filterType=${filterType}&copyright=${copyrightFilter}&page=${currentPage - 1}`) Anterior

          - for (let i = 1; i <= totalPages; i++)
            li.page-item(class=i === currentPage ? 'active' : '')
              a.page-link(href=`/search?q=${query}&tag=${tagFilter}&filterType=${filterType}&copyright=${copyrightFilter}&page=${i}`)= i

          if hasNextPage
            li.page-item
              a.page-link(href=`/search?q=${query}&tag=${tagFilter}&filterType=${filterType}&copyright=${copyrightFilter}&page=${currentPage + 1}`) Siguiente
  else
    .alert.alert-info
      | No se encontraron resultados o la búsqueda está vacía.